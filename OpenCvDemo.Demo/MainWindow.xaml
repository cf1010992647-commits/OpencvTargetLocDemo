<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="OpenCvDemo.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="视觉定位 Demo"
        Width="1480"
        Height="900"
        MinWidth="1280"
        MinHeight="760"
        Background="#F3F6FB"
        FontFamily="Microsoft YaHei UI"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="24"
                Background="White"
                BorderBrush="#D7E0EA"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="Bold"
                               Foreground="#1C2740"
                               Text="视觉定位Demo" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="14,10"
                        Background="#EAF8EF"
                        CornerRadius="14">
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#137333"
                               Text="{Binding StatusMessage}" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="1.25*" />
            </Grid.ColumnDefinitions>

            <Border Padding="20"
                    Background="White"
                    BorderBrush="#D7E0EA"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1C2740"
                               Text="执行入口" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Height="42"
                                 Padding="12,8"
                                 VerticalContentAlignment="Center"
                                 Background="#F7F9FC"
                                 BorderBrush="#CAD4E0"
                                 BorderThickness="1"
                                 FontSize="14"
                                 IsReadOnly="True"
                                 Text="{Binding SelectedImagePath}" />

                        <Button Grid.Column="2"
                                Width="110"
                                Height="42"
                                Background="#1F6FEB"
                                BorderThickness="0"
                                Command="{Binding SelectImageCommand}"
                                Content="选择图片"
                                Foreground="White" />

                        <Button Grid.Column="4"
                                Width="110"
                                Height="42"
                                Background="#0E9F6E"
                                BorderThickness="0"
                                Command="{Binding RunLocateCommand}"
                                Content="执行定位"
                                Foreground="White" />

                        <Button Grid.Column="6"
                                Width="128"
                                Height="42"
                                Background="#EFF3F9"
                                BorderBrush="#CAD4E0"
                                BorderThickness="1"
                                Command="{Binding OpenConfigFolderCommand}"
                                Content="打开配置文件"
                                Foreground="#1C2740" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="20"
                    Background="White"
                    BorderBrush="#D7E0EA"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1C2740"
                                   Text="结果摘要" />
                        <Button Width="104"
                                Height="34"
                                Background="#FFF5E6"
                                BorderBrush="#F0C36D"
                                BorderThickness="1"
                                Command="{Binding ResetConfigCommand}"
                                Content="重置配置"
                                DockPanel.Dock="Right"
                                Foreground="#8A5300" />
                    </DockPanel>

                    <UniformGrid Grid.Row="2"
                                 Columns="2"
                                 Rows="2">
                        <Border Margin="0,0,10,10"
                                Padding="16"
                                Background="#F7F9FC"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock Foreground="#5D6B82" Text="X 偏移" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#1F6FEB"
                                           Text="{Binding OffsetX}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="10,0,0,10"
                                Padding="16"
                                Background="#F7F9FC"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock Foreground="#5D6B82" Text="Y 偏移" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#0E9F6E"
                                           Text="{Binding OffsetY}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,10,10,0"
                                Padding="16"
                                Background="#F7F9FC"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock Foreground="#5D6B82" Text="R 偏移" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#C2410C"
                                           Text="{Binding OffsetR}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="10,10,0,0"
                                Padding="16"
                                Background="#F7F9FC"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock Foreground="#5D6B82" Text="置信度" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#6D28D9"
                                           Text="{Binding Confidence}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <StackPanel Grid.Row="4">
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="#1C2740"
                                   Text="结果 JSON" />
                        <TextBox Height="176"
                                 Margin="0,10,0,0"
                                 Padding="14"
                                 AcceptsReturn="True"
                                 Background="#0F172A"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 Foreground="#D6E3FF"
                                 IsReadOnly="True"
                                 Text="{Binding ResultJson}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="16"
                    Background="White"
                    BorderBrush="#D7E0EA"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1C2740"
                               Text="原始图像" />
                    <Border Grid.Row="2"
                            Background="#F7F9FC"
                            CornerRadius="14">
                        <Image Stretch="Uniform"
                               Source="{Binding OriginalImage}" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="16"
                    Background="White"
                    BorderBrush="#D7E0EA"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1C2740"
                               Text="二值化图像" />
                    <Border Grid.Row="2"
                            Background="#F7F9FC"
                            CornerRadius="14">
                        <Image Stretch="Uniform"
                               Source="{Binding BinaryImage}" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="4"
                    Padding="16"
                    Background="White"
                    BorderBrush="#D7E0EA"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1C2740"
                               Text="识别叠加图像" />
                    <Border Grid.Row="2"
                            Background="#F7F9FC"
                            CornerRadius="14">
                        <Image Stretch="Uniform"
                               Source="{Binding OverlayImage}" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
